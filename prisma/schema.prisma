generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model blockchainpayment {
  id        String   @id
  payer     String
  owner     String
  amount    String
  token     String
  createdAt DateTime @default(now())
}

model booking {
  id                            String         @id
  customerId                    String
  ownerId                       String
  parkingLotId                  String
  status                        booking_status @default(UPCOMING)
  createdAt                     DateTime       @default(now())
  amount                        Float
  endTime                       DateTime       
  startTime                     DateTime       
  vehicleType                   String
  user_booking_customerIdTouser user           @relation("booking_customerIdTouser", fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "Booking_customerId_fkey_unique")
  user_booking_ownerIdTouser    user           @relation("booking_ownerIdTouser", fields: [ownerId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "Booking_ownerId_fkey_unique")
  parkinglot                    parkinglot     @relation(fields: [parkingLotId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "Booking_parkingLotId_fkey_unique")

  @@index([customerId], map: "Booking_customerId_index")
  @@index([ownerId], map: "Booking_ownerId_index")
  @@index([parkingLotId], map: "Booking_parkingLotId_index")
}

model event {
  id              String   @id
  name            String
  description     String?
  lat             Float
  lng             Float
  radiusKm        Float
  startTime       DateTime
  endTime         DateTime
  surgeMultiplier Float    @default(1.3)
  active          Boolean  @default(true)
  createdBy       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime

  @@index([endTime])
  @@index([startTime])
}

model exchangerate {
  id          String   @id
  currency    String   @unique
  rateToUSD   Float
  lastUpdated DateTime
  createdAt   DateTime @default(now())

  @@index([currency])
}

model ownerprofile {
  id           String              @id
  userId       String              @unique(map: "OwnerProfile_userId_key")
  businessName String
  phone        String
  status       ownerprofile_status @default(OWNER_ONBOARDING)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            
  address      String?
  user         user                @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "OwnerProfile_userId_fkey_unique")
  ownerstaff   ownerstaff[]

  @@index([userId], map: "OwnerProfile_userId_index")
}

model ownerstaff {
  id           String          @id
  ownerId      String
  name         String
  email        String
  role         ownerstaff_role
  active       Boolean         @default(true)
  createdAt    DateTime        @default(now())
  ownerprofile ownerprofile    @relation(fields: [ownerId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "OwnerStaff_ownerId_fkey_unique")

  @@index([ownerId], map: "OwnerStaff_ownerId_index")
}

model parkinglot {
  id          String            @id
  ownerId     String
  name        String
  address     String
  lat         Float
  lng         Float
  status      parkinglot_status @default(DRAFT)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          
  booking     booking[]
  user        user              @relation(fields: [ownerId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "ParkingLot_ownerId_fkey_unique")
  parkingslot parkingslot[]
  pricingrule pricingrule[]

  @@index([ownerId], map: "ParkingLot_ownerId_index")
}

model parkingslot {
  id           String           @id
  parkingLotId String
  slotNumber   String
  type         parkingslot_type
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  parkinglot   parkinglot       @relation(fields: [parkingLotId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "ParkingSlot_parkingLotId_fkey_unique")

  @@index([parkingLotId], map: "ParkingSlot_parkingLotId_index")
}

model priceaudit {
  id           String   @id
  parkingLotId String
  oldPrice     Float
  newPrice     Float
  reason       String
  triggeredBy  String?
  eventId      String?
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([parkingLotId])
}

model pricingrule {
  id           String     @id
  parkingLotId String
  basePrice    Float
  hourlyRate   Float
  dynamic      Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   
  currentPrice Float?
  lastUpdated  DateTime?
  parkinglot   parkinglot @relation(fields: [parkingLotId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "PricingRule_parkingLotId_fkey_unique")

  @@index([parkingLotId], map: "PricingRule_parkingLotId_index")
}

model subscription {
  id                   String              @id
  userId               String
  stripeSubscriptionId String              @unique
  plan                 subscription_plan
  status               subscription_status @default(ACTIVE)
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean             @default(false)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime

  @@index([stripeSubscriptionId])
  @@index([userId])
}

model user {
  id                               String        @id
  name                             String
  email                            String        @unique(map: "User_email_key")
  password                         String
  role                             user_role     @default(CUSTOMER)
  lastLoginAt                      DateTime?     
  createdAt                        DateTime      @default(now())
  updatedAt                        DateTime      
  preferredCurrency                String        @default("USD")
  booking_booking_customerIdTouser booking[]     @relation("booking_customerIdTouser")
  booking_booking_ownerIdTouser    booking[]     @relation("booking_ownerIdTouser")
  ownerprofile                     ownerprofile?
  parkinglot                       parkinglot[]
  vehicle                          vehicle[]
}

model vehicle {
  id           String   @id
  userId       String
  licensePlate String
  make         String
  model        String
  color        String
  createdAt    DateTime @default(now())
  updatedAt    DateTime 
  user         user     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "Vehicle_userId_fkey_unique")

  @@index([userId], map: "Vehicle_userId_index")
}

enum parkingslot_type {
  REGULAR
  EV
  DISABLED
}

enum subscription_plan {
  MONTHLY_RESERVED
  CORPORATE
  OWNER_FLEET
  CUSTOM
}

enum booking_status {
  UPCOMING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum ownerprofile_status {
  OWNER_ONBOARDING
  KYC_PENDING
  KYC_REJECTED
  APPROVED
  SUSPENDED
}

enum ownerstaff_role {
  SCANNER
  MANAGER
}

enum subscription_status {
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  INCOMPLETE
  INCOMPLETE_EXPIRED
  TRIALING
}

enum user_role {
  CUSTOMER
  OWNER
  ADMIN
  GATE_OPERATOR
  SUPERVISOR
  MANAGER
}

enum parkinglot_status {
  DRAFT
  ACTIVE
  BLOCKED
}
