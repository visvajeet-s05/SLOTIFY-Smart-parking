generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
  relationMode = "prisma"
}

model user {
  id                               String        @id
  name                             String
  email                            String        @unique(map: "User_email_key")
  password                         String
  role                             Role          @default(CUSTOMER)
  lastLoginAt                      DateTime?
  createdAt                        DateTime      @default(now())
  updatedAt                        DateTime
  preferredCurrency                String        @default("USD")
  booking_booking_customerIdTouser booking[]     @relation("booking_customerIdTouser")
  booking_booking_ownerIdTouser    booking[]     @relation("booking_ownerIdTouser")
  ownerprofile                     ownerprofile?
  vehicle                          vehicle[]
  subscription                     subscription[]

  @@map("user")
}

model ownerprofile {
  id           String              @id
  userId       String              @unique(map: "OwnerProfile_userId_key")
  businessName String
  phone        String
  status       ownerprofile_status @default(OWNER_ONBOARDING)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime
  address      String?
  user         user                @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "OwnerProfile_userId_fkey_unique")
  ownerstaff   ownerstaff[]
  parkinglot   parkinglot[]
  ownerinvoice ownerinvoice[]
  ownerverification ownerverification?
  ownersettlement ownersettlement[]
  ownerincident ownerincident[]
  ownermaintenance ownermaintenance[]
  ownersupportticket ownersupportticket[]
  parkingsetupprogress parkingsetupprogress?

  @@map("OwnerProfile")
}

model ownerstaff {
  id           String          @id
  ownerId      String
  name         String
  email        String
  role         ownerstaff_role
  active       Boolean         @default(true)
  createdAt    DateTime        @default(now())
  ownerprofile ownerprofile    @relation(fields: [ownerId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "OwnerStaff_ownerId_fkey_unique")

  @@map("OwnerStaff")
}

model parkinglot {
  id          String            @id
  ownerId     String
  name        String
  address     String
  lat         Float
  lng         Float
  status      parkinglot_status @default(DRAFT)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime
  booking     booking[]
  ownerprofile ownerprofile     @relation(fields: [ownerId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "ParkingLot_ownerId_fkey_unique")
  parkingslot parkingslot[]
  pricingrule pricingrule[]
  priceaudit priceaudit[]

  @@map("ParkingLot")
}

model parkingslot {
  id           String           @id
  parkingLotId String
  slotNumber   String
  type         parkingslot_type
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  parkinglot   parkinglot       @relation(fields: [parkingLotId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "ParkingSlot_parkingLotId_fkey_unique")

  @@map("ParkingSlot")
}

model pricingrule {
  id           String     @id
  parkingLotId String
  basePrice    Float
  hourlyRate   Float
  dynamic      Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime
  currentPrice Float?
  lastUpdated  DateTime?
  parkinglot   parkinglot @relation(fields: [parkingLotId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "PricingRule_parkingLotId_fkey_unique")

  @@map("PricingRule")
}

model booking {
  id                            String         @id
  customerId                    String
  ownerId                       String
  parkingLotId                  String
  status                        booking_status @default(UPCOMING)
  createdAt                     DateTime       @default(now())
  amount                        Float
  endTime                       DateTime
  startTime                     DateTime
  vehicleType                   String
  user_booking_customerIdTouser user           @relation("booking_customerIdTouser", fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "Booking_customerId_fkey_unique")
  user_booking_ownerIdTouser    user           @relation("booking_ownerIdTouser", fields: [ownerId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "Booking_ownerId_fkey_unique")
  parkinglot                    parkinglot     @relation(fields: [parkingLotId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "Booking_parkingLotId_fkey_unique")
  payment                       payment?

  @@map("Booking")
}

model ownerinvoice {
  id          String   @id
  ownerId     String
  month       Int
  grossAmount Float
  taxAmount   Float
  netAmount   Float
  platformFee Float
  year        Int
  generatedAt DateTime @default(now())
  pdfUrl      String?
  ownerprofile ownerprofile @relation(fields: [ownerId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "OwnerInvoice_ownerId_fkey")

  @@map("OwnerInvoice")
}

model ownerverification {
  id              String   @id
  ownerId         String   @unique(map: "OwnerVerification_ownerId_key")
  documentType    String
  documentUrl     String
  submittedAt     DateTime @default(now())
  reviewedByAdmin String?
  reviewedAt      DateTime?
  rejectionReason String?
  owner           ownerprofile @relation(fields: [ownerId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "OwnerVerification_ownerId_fkey")

  @@map("OwnerVerification")
}

model ownersettlement {
  id          String   @id
  ownerId     String
  amount      Float
  referenceId String
  settledAt   DateTime
  owner       ownerprofile @relation(fields: [ownerId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "OwnerSettlement_ownerId_fkey")

  @@map("OwnerSettlement")
}

model ownerincident {
  id          String   @id
  ownerId     String
  title       String
  description String
  status      ownerincident_status @default(OPEN)
  createdAt   DateTime @default(now())
  resolvedAt  DateTime?
  owner       ownerprofile @relation(fields: [ownerId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "OwnerIncident_ownerId_fkey")

  @@map("OwnerIncident")
}

model ownermaintenance {
  id        String   @id
  ownerId   String
  startTime DateTime
  endTime   DateTime
  reason    String
  createdAt DateTime @default(now())
  owner     ownerprofile @relation(fields: [ownerId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "OwnerMaintenance_ownerId_fkey")

  @@map("OwnerMaintenance")
}

model ownersupportticket {
  id        String   @id
  ownerId   String
  subject   String
  message   String
  status    ownersupport_status @default(OPEN)
  createdAt DateTime @default(now())
  owner     ownerprofile @relation(fields: [ownerId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "OwnerSupportTicket_ownerId_fkey")

  @@map("OwnerSupportTicket")
}

model parkingsetupprogress {
  id            String  @id
  ownerId       String  @unique(map: "ParkingSetupProgress_ownerId_key")
  locationDone  Boolean @default(false)
  slotsDone     Boolean @default(false)
  pricingDone   Boolean @default(false)
  amenitiesDone Boolean @default(false)
  submitted     Boolean @default(false)
  lastStep      String?
  owner         ownerprofile @relation(fields: [ownerId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "ParkingSetupProgress_ownerId_fkey")

  @@map("ParkingSetupProgress")
}

model subscription {
  id                   String              @id
  userId               String
  stripeSubscriptionId String              @unique
  plan                 subscription_plan
  status               subscription_status @default(ACTIVE)
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean             @default(false)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime
  user                 user                @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "subscription_userId_fkey")

  @@map("subscription")
}

model event {
  id              String   @id
  name            String
  description     String?
  lat             Float
  lng             Float
  radiusKm        Float
  startTime       DateTime
  endTime         DateTime
  surgeMultiplier Float    @default(1.3)
  active          Boolean  @default(true)
  createdBy       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime

  @@map("event")
}

model exchangerate {
  id          String   @id
  currency    String   @unique
  rateToUSD   Float
  lastUpdated DateTime
  createdAt   DateTime @default(now())

  @@map("exchangerate")
}

model priceaudit {
  id           String   @id
  parkingLotId String
  oldPrice     Float
  newPrice     Float
  reason       String
  triggeredBy  String?
  eventId      String?
  createdAt    DateTime @default(now())
  parkinglot   parkinglot @relation(fields: [parkingLotId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "priceaudit_parkingLotId_fkey")

  @@map("priceaudit")
}

model demandprediction {
  id          String   @id
  parkingId   String
  hour        Int
  date        DateTime
  demandScore Float
  createdAt   DateTime @default(now())

  @@map("DemandPrediction")
}

model vehicle {
  id           String   @id
  userId       String
  licensePlate String
  make         String
  model        String
  color        String
  createdAt    DateTime @default(now())
  updatedAt    DateTime
  user         user     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "Vehicle_userId_fkey_unique")

  @@map("Vehicle")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model payment {
  id            String   @id
  bookingId     String?  @unique
  stripeId      String?  @unique
  amount        Float
  currency      String
  status        payment_status @default(PENDING)
  region        String?
  cryptoToken   String?
  cryptoChain   String?
  cryptoWallet  String?
  txHash        String?
  confirmedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime
  booking       booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  refund        refund?

  @@map("Payment")
}

model refund {
  id         String   @id
  paymentId  String   @unique
  amount     Float
  txHash     String?
  reason     String
  createdAt  DateTime @default(now())
  payment    payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("Refund")
}

enum payment_status {
  PENDING
  PAID
  FAILED
  CONFIRMED
  REFUNDED
  PARTIAL_REFUND
}

enum parkingslot_type {
  REGULAR
  EV
  DISABLED
}

enum subscription_plan {
  MONTHLY_RESERVED
  CORPORATE
  OWNER_FLEET
  CUSTOM
}

enum booking_status {
  UPCOMING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum ownerprofile_status {
  OWNER_ONBOARDING
  KYC_PENDING
  KYC_REJECTED
  APPROVED
  SUSPENDED
}

enum ownerstaff_role {
  SCANNER
  MANAGER
}

enum subscription_status {
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  INCOMPLETE
  INCOMPLETE_EXPIRED
  TRIALING
}

enum ownerincident_status {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum ownersupport_status {
  OPEN
  IN_PROGRESS
  CLOSED
}

enum Role {
  ADMIN
  OWNER
  CUSTOMER
  STAFF
  GATE_OPERATOR
  SUPERVISOR
  MANAGER
}

enum parkinglot_status {
  DRAFT
  ACTIVE
  BLOCKED
}
