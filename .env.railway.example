# ============================================================
# RAILWAY ENVIRONMENT VARIABLES — SMART PARKING
# ============================================================
# Copy all of these into your Railway service's environment
# variables dashboard (Settings → Variables)
# ============================================================

# ── DATABASE (auto-filled by Railway MySQL plugin) ──────────
# Railway fills this automatically when you add a MySQL plugin.
# It will look like: mysql://root:password@hostname:3306/railway
DATABASE_URL=mysql://USER:PASSWORD@HOST:PORT/railway

# ── NEXTAUTH ────────────────────────────────────────────────
# Set NEXTAUTH_URL to your Railway app's public URL
# e.g. https://smart-parking-production.up.railway.app
NEXTAUTH_URL=https://your-app.up.railway.app
# Generate a secure random secret: openssl rand -base64 32
NEXTAUTH_SECRET=REPLACE_WITH_SECURE_RANDOM_STRING_32_CHARS

# ── PUBLIC BASE URLS ────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=https://your-app.up.railway.app
NEXT_PUBLIC_API_URL=https://your-app.up.railway.app/api

# ── WEBSOCKET SERVER ────────────────────────────────────────
# URL of your Railway WebSocket service (ws-server)
# e.g. wss://smart-parking-ws.up.railway.app
NEXT_PUBLIC_WEBSOCKET_URL=wss://your-ws-server.up.railway.app

# ── AI SERVICE (Owner's Laptop) ─────────────────────────────
# Your laptop's local Python OpenCV service
# This is only used on the OWNER dashboard (not mobile users)
# For production, leave as localhost — owners access via their laptop
NEXT_PUBLIC_AI_SERVICE_URL=http://localhost:5000

# ── STRIPE PAYMENTS ─────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_YOUR_PUBLISHABLE_KEY
STRIPE_SECRET_KEY=sk_live_YOUR_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET

# ── GOOGLE MAPS ─────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_KEY=YOUR_GOOGLE_MAPS_API_KEY

# ── NODE ENV ────────────────────────────────────────────────
NODE_ENV=production

# ── PORT (Railway sets this automatically) ──────────────────
# Do NOT set this manually — Railway injects $PORT automatically
# PORT=3000
