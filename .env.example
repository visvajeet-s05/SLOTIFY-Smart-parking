# Database
DATABASE_URL="mysql://root:1324@localhost:3306/smart_parking"

# Redis
REDIS_URL="redis://localhost:6379"

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_KEY="your_google_maps_api_key"

# Stripe
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_your_publishable_key"

# Authentication
JWT_SECRET="your_jwt_secret_key"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your_nextauth_secret"

# Frontend
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL="http://localhost:3000/api"

# AI/ML - Camera Service
CAMERA_IP="10.145.252.94:8080"
PYTHON_SERVICE_PORT=5000

# AI/ML
TENSORFLOW_MODEL_PATH="./models"
ENABLE_AI_PRICING=true
AI_RETRAIN_INTERVAL="daily"

# Redis Clustering
REDIS_CLUSTER_ENABLED=true
WEBSOCKET_CLUSTER_ENABLED=true

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090

# Caching
CACHE_TTL=300
RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_WINDOW=3600

# Production
NODE_ENV=production
LOG_LEVEL=info