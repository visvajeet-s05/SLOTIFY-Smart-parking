generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model booking {
  id                            String         @id
  customerId                    String
  ownerId                       String
  parkingLotId                  String
  status                        booking_status @default(UPCOMING)
  createdAt                     DateTime       @default(now())
  amount                        Float
  endTime                       DateTime
  startTime                     DateTime
  vehicleType                   String
  user_booking_customerIdTouser user           @relation("booking_customerIdTouser", fields: [customerId], references: [id], map: "Booking_customerId_fkey")
  user_booking_ownerIdTouser    user           @relation("booking_ownerIdTouser", fields: [ownerId], references: [id], map: "Booking_ownerId_fkey")
  parkinglot                    parkinglot     @relation(fields: [parkingLotId], references: [id], map: "Booking_parkingLotId_fkey")
  slotId                        String?        @unique
  slot                          Slot?          @relation(fields: [slotId], references: [id])

  @@index([customerId], map: "Booking_customerId_fkey")
  @@index([slotId])
  @@index([ownerId], map: "Booking_ownerId_fkey")
  @@index([parkingLotId], map: "Booking_parkingLotId_fkey")
}

model demandprediction {
  id          String   @id
  parkingId   String
  hour        Int
  date        DateTime
  demandScore Float
  createdAt   DateTime @default(now())
}

model event {
  id              String   @id
  name            String
  description     String?
  lat             Float
  lng             Float
  radiusKm        Float
  startTime       DateTime
  endTime         DateTime
  surgeMultiplier Float    @default(1.3)
  active          Boolean  @default(true)
  createdBy       String
  createdAt       DateTime @default(now())
  updatedAt       DateTime

  @@index([endTime])
  @@index([startTime])
}

model exchangerate {
  id          String   @id
  currency    String   @unique
  rateToUSD   Float
  lastUpdated DateTime
  createdAt   DateTime @default(now())

  @@index([currency])
}

model maintenanceschedule {
  id         String   @id
  ownerId    String
  parkingLot String
  startDate  DateTime
  endDate    DateTime
  reason     String
  createdAt  DateTime @default(now())
  user       user     @relation(fields: [ownerId], references: [id], map: "MaintenanceSchedule_ownerId_fkey")

  @@index([ownerId], map: "MaintenanceSchedule_ownerId_fkey")
}

model ownerincident {
  id           String               @id
  ownerId      String
  title        String
  description  String
  status       ownerincident_status @default(OPEN)
  createdAt    DateTime             @default(now())
  resolvedAt   DateTime?
  ownerprofile ownerprofile         @relation(fields: [ownerId], references: [id], map: "OwnerIncident_ownerId_fkey")

  @@index([ownerId], map: "OwnerIncident_ownerId_fkey")
}

model ownerinvoice {
  id           String       @id
  ownerId      String
  month        Int
  grossAmount  Float
  taxAmount    Float
  generatedAt  DateTime     @default(now())
  netAmount    Float
  pdfUrl       String?
  platformFee  Float
  year         Int
  ownerprofile ownerprofile @relation(fields: [ownerId], references: [id], map: "OwnerInvoice_ownerId_fkey")

  @@index([ownerId], map: "OwnerInvoice_ownerId_fkey")
}

model ownermaintenance {
  id           String       @id
  ownerId      String
  startTime    DateTime
  endTime      DateTime
  reason       String
  createdAt    DateTime     @default(now())
  ownerprofile ownerprofile @relation(fields: [ownerId], references: [id], map: "OwnerMaintenance_ownerId_fkey")

  @@index([ownerId], map: "OwnerMaintenance_ownerId_fkey")
}

model ownerprofile {
  id                   String                @id
  userId               String                @unique(map: "OwnerProfile_userId_key")
  businessName         String
  phone                String
  status               ownerprofile_status   @default(OWNER_ONBOARDING)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime
  address              String?
  ownerincident        ownerincident[]
  ownerinvoice         ownerinvoice[]
  ownermaintenance     ownermaintenance[]
  user                 user                  @relation(fields: [userId], references: [id], map: "OwnerProfile_userId_fkey")
  ownersettlement      ownersettlement[]
  ownerstaff           ownerstaff[]
  ownersupportticket   ownersupportticket[]
  ownerverification    ownerverification?
  parkinglot           parkinglot[]
  parkingsetupprogress parkingsetupprogress?
}

model ownersettlement {
  id           String       @id
  ownerId      String
  amount       Float
  referenceId  String
  settledAt    DateTime
  ownerprofile ownerprofile @relation(fields: [ownerId], references: [id], map: "OwnerSettlement_ownerId_fkey")

  @@index([ownerId], map: "OwnerSettlement_ownerId_fkey")
}

model ownerstaff {
  id           String          @id
  ownerId      String
  name         String
  email        String
  role         ownerstaff_role
  active       Boolean         @default(true)
  createdAt    DateTime        @default(now())
  ownerprofile ownerprofile    @relation(fields: [ownerId], references: [id], map: "OwnerStaff_ownerId_fkey")

  @@index([ownerId], map: "OwnerStaff_ownerId_fkey")
}

model ownersupportticket {
  id           String                    @id
  ownerId      String
  subject      String
  message      String
  status       ownersupportticket_status @default(OPEN)
  createdAt    DateTime                  @default(now())
  ownerprofile ownerprofile              @relation(fields: [ownerId], references: [id], map: "OwnerSupportTicket_ownerId_fkey")

  @@index([ownerId], map: "OwnerSupportTicket_ownerId_fkey")
}

model ownerverification {
  id              String       @id
  ownerId         String       @unique(map: "OwnerVerification_ownerId_key")
  documentType    String
  documentUrl     String
  submittedAt     DateTime     @default(now())
  reviewedByAdmin String?
  reviewedAt      DateTime?
  rejectionReason String?
  ownerprofile    ownerprofile @relation(fields: [ownerId], references: [id], map: "OwnerVerification_ownerId_fkey")
}

model parkingincident {
  id          String                 @id
  ownerId     String
  bookingId   String?
  description String
  status      parkingincident_status @default(OPEN)
  createdAt   DateTime               @default(now())
  user        user                   @relation(fields: [ownerId], references: [id], map: "ParkingIncident_ownerId_fkey")

  @@index([ownerId], map: "ParkingIncident_ownerId_fkey")
}

model parkinglot {
  id           String            @id
  ownerId      String
  name         String
  address      String
  lat          Float
  lng          Float
  status       parkinglot_status @default(DRAFT)
  cameraUrl    String?
  totalSlots   Int               @default(120)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime
  booking      booking[]
  ownerprofile ownerprofile      @relation(fields: [ownerId], references: [id], onDelete: Cascade, map: "ParkingLot_ownerId_fkey")
  parkingslot  parkingslot[]
  priceaudit   priceaudit[]
  pricingrule  pricingrule[]
  slots        Slot[]

  @@index([ownerId], map: "ParkingLot_ownerId_fkey")
}

model parkingsetupprogress {
  id            String       @id
  ownerId       String       @unique(map: "ParkingSetupProgress_ownerId_key")
  locationDone  Boolean      @default(false)
  slotsDone     Boolean      @default(false)
  pricingDone   Boolean      @default(false)
  amenitiesDone Boolean      @default(false)
  submitted     Boolean      @default(false)
  lastStep      String?
  ownerprofile  ownerprofile @relation(fields: [ownerId], references: [id], map: "ParkingSetupProgress_ownerId_fkey")
}

model parkingslot {
  id           String           @id
  parkingLotId String
  slotNumber   String
  type         parkingslot_type
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  parkinglot   parkinglot       @relation(fields: [parkingLotId], references: [id], onDelete: Cascade, map: "ParkingSlot_parkingLotId_fkey")

  @@index([parkingLotId], map: "ParkingSlot_parkingLotId_fkey")
}

model payment {
  id           String         @id
  bookingId    String?        @unique(map: "Payment_bookingId_key")
  stripeId     String?        @unique(map: "Payment_stripeId_key")
  amount       Float
  currency     String
  status       payment_status @default(PENDING)
  region       String?
  cryptoToken  String?
  cryptoChain  String?
  cryptoWallet String?
  txHash       String?
  confirmedAt  DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime
}

model priceaudit {
  id           String     @id
  parkingLotId String
  oldPrice     Float
  newPrice     Float
  reason       String
  triggeredBy  String?
  eventId      String?
  createdAt    DateTime   @default(now())
  parkinglot   parkinglot @relation(fields: [parkingLotId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@index([parkingLotId])
}

model pricingrule {
  id           String     @id
  parkingLotId String
  basePrice    Float
  hourlyRate   Float
  dynamic      Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime
  currentPrice Float?
  lastUpdated  DateTime?
  parkinglot   parkinglot @relation(fields: [parkingLotId], references: [id], onDelete: Cascade, map: "PricingRule_parkingLotId_fkey")

  @@index([parkingLotId], map: "PricingRule_parkingLotId_fkey")
}

model refund {
  id        String   @id
  paymentId String   @unique(map: "Refund_paymentId_key")
  amount    Float
  txHash    String?
  reason    String
  createdAt DateTime @default(now())
}

model review {
  id        String   @id
  bookingId String
  rating    Int
  comment   String
  response  String?
  createdAt DateTime @default(now())
  updatedAt DateTime
}

model subscription {
  id                   String              @id
  userId               String
  stripeSubscriptionId String              @unique
  plan                 subscription_plan
  status               subscription_status @default(ACTIVE)
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAtPeriodEnd    Boolean             @default(false)
  createdAt            DateTime            @default(now())
  updatedAt            DateTime
  user                 user                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([stripeSubscriptionId])
  @@index([userId])
}

model user {
  id                               String                @id
  name                             String
  email                            String                @unique(map: "User_email_key")
  password                         String
  role                             user_role
  createdAt                        DateTime              @default(now())
  lastLoginAt                      DateTime?
  preferredCurrency                String                @default("USD")
  booking_booking_customerIdTouser booking[]             @relation("booking_customerIdTouser")
  booking_booking_ownerIdTouser    booking[]             @relation("booking_ownerIdTouser")
  maintenanceschedule              maintenanceschedule[]
  ownerprofile                     ownerprofile?
  parkingincident                  parkingincident[]
  subscription                     subscription[]
  vehicle                          vehicle[]
}

model vehicle {
  id           String   @id
  userId       String
  licensePlate String
  make         String
  model        String
  color        String
  createdAt    DateTime @default(now())
  updatedAt    DateTime
  user         user     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "Vehicle_userId_fkey")

  @@index([userId], map: "Vehicle_userId_fkey")
}

enum parkingslot_type {
  REGULAR
  EV
  DISABLED
}

enum subscription_plan {
  MONTHLY_RESERVED
  CORPORATE
  OWNER_FLEET
  CUSTOM
}

enum booking_status {
  UPCOMING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum ownerincident_status {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum ownerprofile_status {
  OWNER_ONBOARDING
  KYC_PENDING
  KYC_REJECTED
  APPROVED
  SUSPENDED
}

enum ownerstaff_role {
  SCANNER
  MANAGER
}

enum ownersupportticket_status {
  OPEN
  IN_PROGRESS
  CLOSED
}

enum parkingincident_status {
  OPEN
  IN_PROGRESS
  RESOLVED
}

enum subscription_status {
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  INCOMPLETE
  INCOMPLETE_EXPIRED
  TRIALING
}

enum user_role {
  CUSTOMER
  OWNER
  ADMIN
  GATE_OPERATOR
  SUPERVISOR
  MANAGER
}

enum payment_status {
  PENDING
  PAID
  FAILED
  CONFIRMED
  REFUNDED
  PARTIAL_REFUND
}

enum parkinglot_status {
  DRAFT
  ACTIVE
  BLOCKED
}

// Smart Parking System - Real-time Slot Management
enum SlotStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  DISABLED
  CLOSED
}

enum UpdatedBy {
  AI
  OWNER
  CUSTOMER
}

model Slot {
  id           String     @id @default(cuid())
  lotId        String
  slotNumber   Int
  row          String
  x            Int?
  y            Int?
  width        Int?
  height       Int?
  status       SlotStatus @default(AVAILABLE)
  aiConfidence Float      @default(100.0)
  updatedBy    UpdatedBy  @default(AI)
  updatedAt    DateTime   @updatedAt
  price        Float      @default(50.0)
  slotType     String     @default("REGULAR")
  displayName  String?

  parkingLot parkinglot @relation(fields: [lotId], references: [id])
  booking    booking?

  @@unique([lotId, slotNumber])
  @@index([lotId])
  @@index([status])
}

model SlotStatusLog {
  id           String     @id @default(cuid())
  slotId       String
  oldStatus    SlotStatus
  newStatus    SlotStatus
  updatedBy    UpdatedBy
  aiConfidence Float      @default(100.0)
  createdAt    DateTime   @default(now())

  @@index([slotId])
  @@index([createdAt])
}
